{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "BotAr",
  "version": "2.0.0",
  "identifier": "com.botar.desktop",
  "build": {
    "frontendDist": "../dashboard/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd dashboard && npx vite",
    "beforeBuildCommand": "npm run build --prefix dashboard"
  },
  "app": {
    "windows": [
      {
        "title": "BotAr",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
